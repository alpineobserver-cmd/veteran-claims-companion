generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  name String?
  email String? @unique
  emailVerified DateTime?
  image String?
  passwordHash String?
  accounts Account[]
  sessions Session[]
  claims Claim[]
  uploads Upload[]
  documents Document[]
  auditEvents AuditEvent[] @relation("AuditActor")
  statements Statement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id String @id @default(cuid())
  userId String
  claimId String
  originalName String
  storageKey String @unique
  mimeType String
  size Int
  sha256 String
  provider String
  status DocumentStatus @default(TEST_ONLY)
  syntheticConfirmed Boolean @default(false)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  pages DocumentPage[]
  auditEvents AuditEvent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([claimId, createdAt])
}

model DocumentPage {
  id String @id @default(cuid())
  documentId String
  pageNumber Int
  ocrText String? @db.Text
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, pageNumber])
}

model AuditEvent {
  id String @id @default(cuid())
  actorUserId String
  claimId String?
  documentId String?
  action AuditAction
  metadata Json?
  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  claim Claim? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([claimId, createdAt])
}

model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? @db.Text
  access_token String? @db.Text
  expires_at Int?
  token_type String?
  scope String?
  id_token String? @db.Text
  session_state String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token String @unique
  expires DateTime
  @@unique([identifier, token])
}

model RateLimitBucket {
  id String @id @default(cuid())
  scope String
  principalHash String
  windowStart DateTime
  windowEndsAt DateTime
  count Int @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, principalHash, windowStart])
  @@index([windowEndsAt])
}

model StorageReconciliationTask {
  id String @id @default(cuid())
  fingerprint String @unique
  principalHash String
  operation String
  scope String
  entityId String?
  storageKey String?
  status String @default("PENDING")
  attempts Int @default(1)
  lastErrorCode String
  lastAttemptAt DateTime @default(now())
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([principalHash, status])
  @@index([status, createdAt])
}

model Claim {
  id String @id @default(cuid())
  userId String
  title String
  status ClaimStatus @default(DRAFT)
  branch String?
  mosRate String?
  symptomStart DateTime?
  deploymentHistory String?
  exposures String?
  treatment String?
  progress Int @default(0)
  draftData Json?
  draftVersion Int @default(1)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  conditions ClaimCondition[]
  evidence Evidence[]
  answers Answer[]
  progressItems Progress[]
  statements Statement[]
  documents Document[]
  auditEvents AuditEvent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Condition {
  id String @id @default(cuid())
  slug String @unique
  name String
  overview String
  ratingCriteria String
  typicalEvidence String
  requiredDiagnosis String
  commonMistakes String
  helpfulDocumentation String
  relatedConditions String?
  claims ClaimCondition[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClaimCondition {
  claimId String
  conditionId String
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  condition Condition @relation(fields: [conditionId], references: [id])
  @@id([claimId, conditionId])
}

model EvidenceType {
  id String @id @default(cuid())
  slug String @unique
  name String
  category String
  description String
  purpose String
  strength String
  whenToUse String
  commonMistakes String
  examples String
  evidence Evidence[]
}

model Evidence {
  id String @id @default(cuid())
  claimId String
  evidenceTypeId String
  title String
  notes String?
  status EvidenceStatus @default(IDENTIFIED)
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  type EvidenceType @relation(fields: [evidenceTypeId], references: [id])
  uploads Upload[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Upload {
  id String @id @default(cuid())
  userId String
  evidenceId String?
  filename String
  storageKey String
  mimeType String
  size Int
  provider String @default("local")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence Evidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Template {
  id String @id @default(cuid())
  slug String @unique
  name String
  category String
  purpose String
  instructions String
  body String
  statements Statement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Statement {
  id String @id @default(cuid())
  userId String
  claimId String?
  templateId String?
  title String
  content String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  claim Claim? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VAForm {
  id String @id @default(cuid())
  slug String @unique
  formNumber String
  name String
  purpose String
  description String
  whenToUse String
  completedBy String
  typicalMistakes String
  status String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id String @id @default(cuid())
  key String @unique
  prompt String
  helpText String?
  kind QuestionKind @default(TEXT)
  order Int
  answers Answer[]
  createdAt DateTime @default(now())
}

model Answer {
  id String @id @default(cuid())
  claimId String
  questionId String
  value Json
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([claimId, questionId])
}

model Progress {
  id String @id @default(cuid())
  claimId String
  key String
  label String
  complete Boolean @default(false)
  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
  @@unique([claimId, key])
}

enum ClaimStatus {
  DRAFT
  IN_PROGRESS
  READY
  ARCHIVED
}

enum EvidenceStatus {
  IDENTIFIED
  REQUESTED
  UPLOADED
  REVIEWED
}

enum QuestionKind {
  TEXT
  TEXTAREA
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
}

enum DocumentStatus {
  TEST_ONLY
  QUARANTINED
  READY
  REJECTED
}

enum AuditAction {
  WORKSPACE_CREATED
  DOCUMENT_UPLOADED
  DOCUMENT_DOWNLOADED
  DOCUMENT_DELETED
}
