{
  "name": "veteran-claims-companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run deployment:env-check && npm run auth:env-check && prisma migrate deploy && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "auth:env-check": "node scripts/validate-auth-env.mjs",
    "auth:release-check": "node scripts/check-auth-release.mjs",
    "deployment:env-check": "node scripts/validate-deployment-env.mjs",
    "test:deployment": "node --test tests/deployment-environment.test.mjs",
    "test:auth": "node --import tsx --test tests/auth-boundary.test.mjs tests/canonical-host.test.ts",
    "test:links": "node --test tests/canonical-links.test.mjs",
    "test:accessibility": "node --test tests/accessibility-contract.test.mjs",
    "test:storage": "node --import tsx --test tests/document-storage-security.test.ts tests/document-upload-security.test.ts",
    "test:controls": "node --import tsx --test tests/operational-controls.test.ts",
    "test:data-controls": "node --import tsx --test tests/account-data-controls.test.ts",
    "test:rate-limit": "node --import tsx --test tests/durable-rate-limit.test.ts",
    "test:reconciliation": "node --import tsx --test tests/storage-reconciliation.test.ts",
    "test:api-security": "node --import tsx --test tests/api-isolation-security.test.ts",
    "test:isolation-e2e": "node --import tsx --test tests/database-two-user-isolation.test.ts",
    "test:legal": "node --test tests/legal-boundaries.test.mjs",
    "test:runbooks": "node --test tests/operational-runbooks.test.mjs",
    "test:claim-process": "node --import tsx --test tests/claim-process.test.mjs tests/claim-package-workflow.test.ts",
    "test:usability": "node --import tsx --test tests/usability-simulation.test.ts",
    "test:unit": "npm run test:deployment && npm run test:links && npm run test:accessibility && npm run test:runbooks && npm run test:claim-process && npm run test:usability && npm run eval:claims && npm run eval:alpha",
    "test:integration": "npm run test:storage && npm run test:data-controls && npm run test:reconciliation",
    "test:security": "npm run test:controls && npm run test:rate-limit && npm run test:api-security && npm run test:isolation-e2e && npm run test:auth && npm run test:legal",
    "test:release": "npm run test:deployment && npm run test:links && npm run test:accessibility && npm run test:storage && npm run test:controls && npm run test:data-controls && npm run test:rate-limit && npm run test:reconciliation && npm run test:api-security && npm run test:isolation-e2e && npm run test:legal && npm run test:runbooks && npm run test:claim-process && npm run test:usability && npm run test:auth && npm run eval:claims && npm run eval:alpha",
    "check:dependencies": "npm ls --depth=0 && npm audit --audit-level=high",
    "eval:alpha": "node scripts/summarize-alpha-sessions.mjs",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "eval:claims": "node --import tsx evals/run-claim-evals.ts",
    "eval:usability": "node --import tsx evals/run-usability-evals.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.1.0",
    "@vercel/blob": "^2.3.0",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.2",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.19"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "prisma@6.19.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
